{
  "name": "agent-cli",
  "version": "0.1.0",
  "description": "Agente CLI adaptável para qualquer stack",
  "bin": {
    "agent": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node -r ts-node/register src/index.ts",
    "dev:test": "node -r ts-node/register src/test-filesystem.ts",
    "dev:test-detector": "node -r ts-node/register src/test-detector.ts",
    "dev:test-provider": "node -r ts-node/register src/test-provider.ts",
    "dev:test-rag": "node -r ts-node/register src/test-rag.ts",
    "dev:test-context-builder": "node -r ts-node/register src/test-context-builder.ts",
    "dev:test-agent": "node -r ts-node/register src/test-agent-core.ts",
    "dev:test-init": "node -r ts-node/register src/test-init.ts",
    "dev:test-generate": "node -r ts-node/register src/test-generate.ts",
    "dev:test-run": "node -r ts-node/register src/test-run.ts",
    "dev:test-chat": "node -r ts-node/register src/test-chat.ts",
    "dev:test-new": "node -r ts-node/register src/test-new.ts",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.21",
    "@langchain/core": "^1.1.29",
    "@langchain/google-genai": "^2.1.23",
    "@langchain/openai": "^1.2.11",
    "chalk": "^4.0.0",
    "commander": "^12.0.0",
    "inquirer": "^8.0.0",
    "ora": "^5.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.0.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
